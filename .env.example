# Environment: "dev" or "prod"
REFLEX_ENV=dev

# Dev ports (only used when REFLEX_ENV=dev)
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Exclude data dir from hot-reload watcher (prevents bot_profile wipe)
REFLEX_HOT_RELOAD_EXCLUDE_PATHS=data

# Prod port (only used when REFLEX_ENV=prod, single-port mode)
PORT=2009

# App settings
LOG_LEVEL=INFO
USERS=admin:changeme,analyst:changeme
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Path to a YAML file with custom rules for solution checking (optional)
CUSTOM_RULES_FILE=data/default_rules.yaml
